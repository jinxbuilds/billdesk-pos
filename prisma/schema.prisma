// ============================================================
// Restaurant POS — Multi-tenant Prisma Schema (v1.1)
// Adds: restaurant_id on every table, atomic bill numbering,
// idempotent offline sync, PIN-based staff auth.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// TENANT ROOT
// ------------------------------------------------------------

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  // Atomic counter for human-readable bill numbers.
  // Incremented via prisma.restaurant.update({ data: { nextBillNumber: { increment: 1 } } })
  // which compiles to a single atomic UPDATE ... RETURNING in Postgres —
  // safe even if two devices sync at the exact same millisecond.
  nextBillNumber Int @default(0)

  staff     Staff[]
  devices   Device[]
  menuItems MenuItem[]
  bills     Bill[]
  settings  Settings?
}

// ------------------------------------------------------------
// STAFF / AUTH
// ------------------------------------------------------------

enum Role {
  OWNER
  CASHIER
}

model Staff {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  name      String
  role      Role
  pinHash   String // bcrypt hash of 4-6 digit PIN, never store plain PIN
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  bills Bill[] // bills created by this staff member

  @@index([restaurantId])
}

// ------------------------------------------------------------
// DEVICES
// ------------------------------------------------------------

model Device {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  deviceName String // "Counter 1", "Owner Phone"
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  bills Bill[]

  @@index([restaurantId])
}

// ------------------------------------------------------------
// MENU
// ------------------------------------------------------------

model MenuItem {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  name      String
  price     Decimal  @db.Decimal(10, 2)
  category  String // flat string, no nesting — matches MVP design
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  billItems BillItem[]

  @@index([restaurantId, category])
  @@index([restaurantId, active])
}

// ------------------------------------------------------------
// BILLS
// ------------------------------------------------------------

enum PaymentMode {
  CASH
  UPI
  CARD
}

enum DiscountType {
  NONE
  FLAT
  PERCENT
}

enum BillStatus {
  COMPLETED // created while online
  OFFLINE_SYNCED // created offline, later synced
}

model Bill {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  // Server-assigned, atomic, sequential per restaurant. Shown on receipts.
  billNumber Int

  // Client-generated UUID, set at bill creation time on-device.
  // Unique per restaurant. Lets sync retries be idempotent —
  // if the same offline bill is uploaded twice, the second
  // attempt is detected and skipped instead of duplicating the sale.
  clientBillId String

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  subtotal           Decimal      @db.Decimal(10, 2)
  discountType       DiscountType @default(NONE)
  discountValue      Decimal      @default(0) @db.Decimal(10, 2) // flat ₹ amount, or % value (e.g. 10)
  discountAmount     Decimal      @default(0) @db.Decimal(10, 2) // resolved ₹ amount after applying type
  roundingAdjustment Decimal      @default(0) @db.Decimal(10, 2) // can be negative
  totalAmount        Decimal      @db.Decimal(10, 2)

  paymentMode PaymentMode
  status      BillStatus  @default(COMPLETED)

  createdAt DateTime  @default(now()) // when cashier actually created it (device clock)
  syncedAt  DateTime? // when it landed in Postgres (server clock), null if created online

  items BillItem[]

  @@unique([restaurantId, clientBillId]) // idempotency guard
  @@unique([restaurantId, billNumber]) // guarantees no duplicate display numbers
  @@index([restaurantId, createdAt]) // fast "today's bills" queries
  @@index([restaurantId, status])
}

model BillItem {
  id     String @id @default(cuid())
  billId String
  bill   Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)

  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])

  // Snapshot fields — preserve historical accuracy even if menu changes later
  itemName  String
  price     Decimal @db.Decimal(10, 2)
  qty       Int
  lineTotal Decimal @db.Decimal(10, 2)

  @@index([billId])
}

// ------------------------------------------------------------
// SETTINGS
// ------------------------------------------------------------

model Settings {
  id           String     @id @default(cuid())
  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  roundingEnabled Boolean  @default(false)
  discountEnabled Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}
